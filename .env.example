# GEDOS — Copy to .env and fill in your values
# Never commit .env to version control.

# Required for Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional extra chats that may use the bot after the owner claims it
ALLOWED_CHAT_IDS=
# Optional fixed pairing code. If blank, Gedos generates a one-time claim code on first startup and logs it locally.
PAIRING_CODE=

# LLM (optional — Ollama is used by default, no key required)
# LLM_PROVIDER=ollama
# LLM_PROVIDER=claude
# LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# GitHub CI self-healing (v0.9.6)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_PORT=9876
