# GEDOS — Copy to .env and fill in your values
# Never commit .env to version control.

# Required for Telegram bot
TELEGRAM_BOT_TOKEN=

# LLM (optional — Ollama is used by default, no key required)
# LLM_PROVIDER=ollama
# LLM_PROVIDER=claude
# LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
